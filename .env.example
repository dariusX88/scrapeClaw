# ScrapeClaw Configuration
# Copy this file to .env and fill in your keys

# Required: Claude API key for intelligent extraction
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: Database URL (default: SQLite)
SCRAPECLAW_DB_URL=sqlite:///scrapeclaw.db

# Optional: Output directory (default: ./output)
SCRAPECLAW_OUTPUT_DIR=./output

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
SCRAPECLAW_LOG_LEVEL=INFO
